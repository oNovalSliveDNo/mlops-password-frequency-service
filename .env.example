# =========================
# App
# =========================
APP_NAME=mlops-password-frequency-service
APP_ENV=local
LOG_LEVEL=INFO
# Optional stable per-process diagnostic id; defaults to HOSTNAME.
INSTANCE_ID=

# For local run you can use 8000.
PORT=8000

# =========================
# MLflow
# =========================
MLFLOW_TRACKING_URI=
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
MLFLOW_S3_ENDPOINT_URL=

# Model Registry name.
MODEL_NAME=
MODEL_ALIAS=prod

# =========================
# S3 / Object Storage for MLflow artifacts
# =========================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =========================
# GitLab pipeline trigger
# Used by POST /trigger to start training pipeline directly via
# POST /projects/:id/trigger/pipeline. Requires only a GitLab pipeline
# trigger token; no project access token / GITLAB_TOKEN is needed.
# =========================
GITLAB_URL=
GITLAB_PROJECT_ID=
GITLAB_REF=main
GITLAB_TRIGGER_TOKEN=

# =========================
# Internal model reload
# Used by GitLab train job to call POST /reload_model
# =========================
SERVICE_RELOAD_URL=
SERVICE_RELOAD_SECRET=

# Optional overrides; derived from SERVICE_RELOAD_URL when empty
SERVICE_HEALTH_URL=
# Optional comma-separated direct state URLs, one per serving replica.
# Use when the deployment is scaled beyond one instance.
SERVICE_REPLICA_STATE_URLS=
SERVICE_PREDICT_URL=
# Post-reload verification: sample 20-50 training rows and check /predict repeatedly
SERVICE_PREDICT_CHECK_ROWS=20
SERVICE_SERVING_VERIFICATION_ROUNDS=3
SERVICE_PREDICT_MAX_ABS_ERROR_TOLERANCE=0.5

# =========================
# DockerHub
# Used by GitLab CI/CD build stage
# =========================
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# =========================
# Amvera deploy
# Used only in GitLab CI/CD deploy stage
# =========================
AMVERA_GIT_URL=
AMVERA_USERNAME=
AMVERA_PASSWORD=

# =========================
# Training pipeline
# Passed automatically by /trigger
# =========================
DATA_URL=
FAIL_CI_ON_VALIDATION_FAILED=false
FAIL_CI_ON_SERVING_VERIFICATION_FAILED=false